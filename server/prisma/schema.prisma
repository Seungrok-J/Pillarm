generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum MemberRole {
  admin
  viewer
  notifyOnly
}

enum ShareScope {
  all
  specificMedication
  specificSchedule
}

enum NotificationPolicy {
  realtime
  dailySummary
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  /// 이메일 가입: 필수. Apple 숨김 이메일 사용 시 null 가능.
  email        String?  @unique
  passwordHash String?
  /// 표시 이름 (이메일 가입 시 직접 입력, 소셜 로그인 시 provider 값)
  name         String?
  /// OAuth provider (null = 이메일 가입, "apple" | "google" | "kakao" | "naver")
  provider     String?
  /// 소셜 제공자의 고유 사용자 ID
  providerId   String?
  /// FCM 등록 토큰 (로그인 시 앱에서 업데이트)
  fcmToken     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedCircles  CareCircle[]        @relation("CircleOwner")
  memberships   CareMember[]        @relation("MemberUser")
  refreshTokens RefreshToken[]
  snapshots     DoseEventSnapshot[] @relation("SnapshotPatient")
  medications   Medication[]        @relation("UserMedications")
  schedules     Schedule[]          @relation("UserSchedules")
  doseEvents    DoseEvent[]         @relation("UserDoseEvents")

  @@unique([provider, providerId])
}

model CareCircle {
  id          String   @id @default(cuid())
  ownerUserId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User                @relation("CircleOwner", fields: [ownerUserId], references: [id])
  members     CareMember[]
  policies    SharePolicy[]
  inviteCodes InviteCode[]
  snapshots   DoseEventSnapshot[]
}

model CareMember {
  id           String     @id @default(cuid())
  careCircleId String
  memberUserId String
  role         MemberRole @default(viewer)
  /// 보호 그룹 소유자(환자)가 붙인 별칭 (예: "엄마", "할머니")
  nickname     String?
  createdAt    DateTime   @default(now())

  careCircle CareCircle @relation(fields: [careCircleId], references: [id], onDelete: Cascade)
  member     User       @relation("MemberUser", fields: [memberUserId], references: [id])

  @@unique([careCircleId, memberUserId])
}

model SharePolicy {
  id                 String             @id @default(cuid())
  careCircleId       String
  shareScope         ShareScope         @default(all)
  /// 공개 허용 필드: e.g. ["status","time","note"]
  allowedFields      String[]
  notificationPolicy NotificationPolicy @default(realtime)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  careCircle CareCircle @relation(fields: [careCircleId], references: [id], onDelete: Cascade)
}

/// 클라이언트 SQLite DoseEvent 의 일별 스냅샷. 보호자 뷰에 사용.
model DoseEventSnapshot {
  id           String   @id @default(cuid())
  careCircleId String
  patientId    String
  /// YYYY-MM-DD
  date         String
  /// DoseEvent[] JSON (SharePolicy.allowedFields 필터 적용 후)
  data         Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  careCircle CareCircle @relation(fields: [careCircleId], references: [id], onDelete: Cascade)
  patient    User       @relation("SnapshotPatient", fields: [patientId], references: [id])

  @@unique([careCircleId, patientId, date])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Sync models ───────────────────────────────────────────────────────────────

/// 앱 로컬 SQLite 의 Medication 을 서버에 미러링 (기기 이전·복원용)
model Medication {
  id          String  @id
  userId      String
  name        String
  dosageValue Float?
  dosageUnit  String?
  color       String?
  isActive    Boolean @default(true)
  /// ISO 8601 문자열 (앱 로컬 createdAt 그대로 저장)
  createdAt   String
  /// 마지막 업데이트 시각 — conflict resolution 기준
  updatedAt   String

  user User @relation("UserMedications", fields: [userId], references: [id], onDelete: Cascade)
}

/// 앱 로컬 SQLite 의 Schedule 을 서버에 미러링
model Schedule {
  id           String   @id
  userId       String
  medicationId String
  scheduleType String   @default("fixed")
  startDate    String
  endDate      String?
  times        String[]
  daysOfWeek   Int[]
  withFood     String   @default("none")
  graceMinutes Int      @default(120)
  isActive     Boolean  @default(true)
  createdAt    String
  updatedAt    String

  user User @relation("UserSchedules", fields: [userId], references: [id], onDelete: Cascade)
}

/// 앱 로컬 SQLite 의 DoseEvent 를 서버에 미러링 (최근 90일)
model DoseEvent {
  id           String  @id
  userId       String
  scheduleId   String
  medicationId String
  plannedAt    String
  status       String
  takenAt      String?
  snoozeCount  Int     @default(0)
  source       String  @default("notification")
  note         String?
  createdAt    String
  updatedAt    String

  user User @relation("UserDoseEvents", fields: [userId], references: [id], onDelete: Cascade)
}

/// 6자리 일회용 초대 코드 (24h TTL)
model InviteCode {
  id           String    @id @default(cuid())
  careCircleId String
  code         String    @unique
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  careCircle CareCircle @relation(fields: [careCircleId], references: [id], onDelete: Cascade)
}
