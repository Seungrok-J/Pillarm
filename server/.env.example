# ── Database ──────────────────────────────────────────────────────────────────
# 로컬 PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pillarm?schema=public"

# Prisma migrations 용 직접 연결 URL.
# 로컬 개발 시: DATABASE_URL 과 동일하게 설정
# Supabase/PgBouncer 사용 시: 풀러 우회 직접 연결 URL 입력
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/pillarm?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
# 각각 서로 다른 랜덤 64바이트 hex 문자열로 설정할 것
# 생성 명령: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-64-byte-random-hex"
JWT_REFRESH_SECRET="replace-with-different-64-byte-random-hex"

# ── Firebase Admin (FCM 푸시 알림 — 선택) ─────────────────────────────────────
# Firebase Console → 프로젝트 설정 → 서비스 계정에서 JSON 키 다운로드
# 없으면 FCM 비활성화 상태로 서버 기동 (보호자 푸시 알림만 비활성)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# 개행 문자를 \n 으로 이스케이프하여 한 줄로 입력
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
